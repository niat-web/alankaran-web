{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/assets/.*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/images/.*",
      "headers": {
        "cache-control": "public, max-age=604800"
      }
    },
    {
      "src": "/(?!assets/|images/).*",
      "dest": "/index.html"
    }
  ]
}
